# App auth (Google OAuth for production; optional in local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=

# Optional allowlist for sign-in emails (comma-separated)
HELVA_ALLOWED_EMAILS=

# Postgres (required for ingest route and usage dashboard data)
DATABASE_URL=

# Shared secret for collector -> /api/ingest/openclaw
HELVA_COLLECTOR_TOKEN=
