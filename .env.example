# Convex (required - set automatically by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=

# Admin import bypass for server-side scripts
ADMIN_IMPORT_SECRET=

# ── Convex deployment env vars (set via `npx convex env set <KEY> <VALUE>`) ──
#
# Auth keys (set automatically by `npx @convex-dev/auth`):
#   JWT_PRIVATE_KEY=...
#   JWKS=...
#   SITE_URL=http://localhost:3000    (dev) or https://helva.cloud (prod)
#   Use http://localhost:3000 as the only local app origin.
#   Requests to 127.0.0.1 / [::1] are redirected to localhost in dev.
#   Use HTTPS locally only if you have local certificates configured.
#
# Google OAuth:
#   AUTH_GOOGLE_ID=...
#   AUTH_GOOGLE_SECRET=...
#   The current auth code also accepts AUTH_GOOGLE_CLIENT_ID /
#   AUTH_GOOGLE_CLIENT_SECRET for backwards compatibility.
#   → Add redirect URI to Google Console:
#     {SITE_URL}/api/auth/callback/google
#
# Email magic links via Resend (optional):
#   AUTH_RESEND_KEY=re_...
#   AUTH_EMAIL_FROM=Helva Cloud <noreply@helva.cloud>
#   The sender domain in AUTH_EMAIL_FROM must be verified in Resend.
#
# Shared secret for collector -> /api/ingest/openclaw
HELVA_COLLECTOR_TOKEN=
